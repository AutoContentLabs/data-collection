# MongoDB
MONGO_INITDB_ROOT_USERNAME=root
MONGO_INITDB_ROOT_PASSWORD=secret

# PostgreSQL
POSTGRES_USER=admin
POSTGRES_PASSWORD=admin_password
POSTGRES_DB=mydatabase

# InfluxDB
INFLUXDB_DB=myinfluxdb
INFLUXDB_ADMIN_USER=admin
INFLUXDB_ADMIN_PASSWORD=admin123

# Cassandra
CASSANDRA_CLUSTER_NAME=my_cluster

# Elasticsearch (opsiyonel)
# Elasticsearch bu projede ortam değişkenleri ile ayarlanmadığı için bu kısmı kaldırabilirsiniz.

# ClickHouse (opsiyonel)
# Eğer özel bir ClickHouse ortam değişkeni gerekirse buraya eklenebilir.
